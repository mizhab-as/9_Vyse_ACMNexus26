#!/bin/bash
# Setup environment for NEXUS Triage System

# Backend configuration
export OPENAI_API_KEY="sk-test-placeholder-for-demo"
export BACKEND_HOST="0.0.0.0"
export BACKEND_PORT="8000"
export FRONTEND_URL="http://localhost:3000"

# ML Configuration
export ML_CONTAMINATION="0.05"  # Lower = more sensitive to anomalies
export ML_WINDOW_SIZE="15"      # More samples for trend analysis

echo "[SETUP] Environment variables configured"
echo "  OPENAI_API_KEY: $OPENAI_API_KEY"
echo "  BACKEND: $BACKEND_HOST:$BACKEND_PORT"
echo "  FRONTEND: $FRONTEND_URL"
