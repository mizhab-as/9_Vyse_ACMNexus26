# Real-Time Data Source Configuration

# ============== ADAPTER SELECTION ==============
# Options: ehr, mqtt, device
ADAPTER_TYPE=ehr

# ============== EHR/REST API CONFIGURATION ==============
# Generic REST API endpoint for hospital EHR systems
EHR_API_URL=http://hospital-ehr.example.com
EHR_API_KEY=your_api_key_here

# FHIR-specific (if using FHIRAdapter)
# FHIR_BASE_URL=https://fhir.hospital.example.com
# FHIR_PATIENT_ID=patient-123456
# FHIR_API_KEY=fhir_api_key

# ============== MQTT CONFIGURATION ==============
# For IoT devices (pulse oximeters, ambulance sensors, etc.)
MQTT_BROKER=mqtt.example.com
MQTT_TOPIC=ambulance/vitals
MQTT_PORT=1883
# Optional: MQTT_USERNAME=user
# Optional: MQTT_PASSWORD=pass

# ============== WEBsocket DEVICE CONFIGURATION ==============
# Direct connection to ambulance monitoring device
DEVICE_WS_URL=ws://ambulance-device.local:8080/vitals

# ============== NEXUS BACKEND ==============
BACKEND_URL=ws://localhost:8000/ws/ambulance

# ============== PATIENT & POLLING ==============
PATIENT_ID=REAL_P001
POLLING_INTERVAL=10

# ============== OPTIONAL: LLM INTEGRATION ==============
OPENAI_API_KEY=sk-...

# ============== OPTIONAL: MONITORING & LOGGING ==============
LOG_LEVEL=INFO
# LOG_FILE=nexus_stream.log
